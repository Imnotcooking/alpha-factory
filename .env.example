# Copy this file to .env locally and fill in real values there.
# Never commit .env or real broker/vendor secrets.

# Market data vendors
FMP_API_KEY=
MASSIVE_API_KEY=
MASSIVE_FLAT_FILES_ACCESS_KEY_ID=
MASSIVE_FLAT_FILES_SECRET_ACCESS_KEY=
MASSIVE_FLAT_FILES_ENDPOINT=https://files.massive.com
MASSIVE_FLAT_FILES_BUCKET=flatfiles

# AI-assisted research and reporting
OPENAI_API_KEY=
ZAI_API_KEY=
LLM_PROVIDER=zai
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-5.2
LLM_EVIDENCE_ENABLED=false
LLM_TIMEOUT_SECONDS=60
LLM_CACHE_MAX_AGE_HOURS=168
GEMINI_API_KEY=

# Interactive Brokers
# Do not put your IBKR username or password here.
# Log in through TWS or IB Gateway; the app only connects to the local API socket.
# TWS: paper often uses 7497, live often uses 7496.
# IB Gateway: paper often uses 4002, live often uses 4001.
# Match the port shown in your local TWS/Gateway API settings.
IBKR_HOST=127.0.0.1
IBKR_PAPER_PORT=7497
IBKR_LIVE_PORT=7496
IBKR_CLIENT_ID=101
IBKR_PAPER_CLIENT_ID=101
IBKR_PAPER_SUBMIT_CLIENT_ID=121
IBKR_LIVE_CLIENT_ID=201
IBKR_LIVE_MONITOR_ENABLED=false

# QMT / XtQuant connector
# MiniQMT should run on the Windows QMT host. OQP talks to a small connector
# service on that host; QMT submit is gated separately from IBKR submit.
QMT_CONNECTOR_ENABLED=false
QMT_CONNECTOR_URL=http://127.0.0.1:58668
QMT_SUBMIT_CONNECTOR_URL=http://127.0.0.1:58669
QMT_API_TOKEN=
QMT_REQUEST_SIGNING_SECRET=
QMT_AUDIT_LOG_PATH=runtime/logs/qmt_connector_audit.jsonl
QMT_REQUIRE_PRIVATE_CONNECTOR=true
QMT_ACCOUNT_ID=
QMT_PAPER_ACCOUNT_ID=
QMT_LIVE_ACCOUNT_ID=
QMT_ACCOUNT_TYPE=STOCK
QMT_SESSION_ID=880001
QMT_TIMEOUT_SECONDS=5
QMT_LIVE_MONITOR_ENABLED=false
ALLOW_QMT_PAPER_ORDER_SUBMIT=false
ALLOW_QMT_LIVE_TRADING=false

# Ops dashboard status source:
# direct   = probe local IBKR sockets/API directly, best on the Ubuntu server
# snapshot = read synced server health files/ledgers, best on your Mac dashboard
OQP_OPS_STATUS_SOURCE=snapshot

# Runtime mode and safety controls
TRADING_MODE=paper
ALLOW_LIVE_TRADING=false
ALLOW_PAPER_TRADING=false
ALLOW_PAPER_ORDER_SUBMIT=false
PAPER_MAX_ORDER_NOTIONAL=10000
PAPER_MAX_DAILY_NOTIONAL=50000
PAPER_ALLOWED_SYMBOLS=
PAPER_ALLOWED_ASSET_CLASSES=equity,etf
PAPER_OPTIONS_ENABLED=false
PAPER_OPTION_ALLOWED_UNDERLYINGS=
PAPER_OPTION_ALLOWED_STRATEGIES=
PAPER_OPTION_MAX_CONTRACTS=1
PAPER_OPTION_MAX_PREMIUM=500
PAPER_OPTION_MAX_DEFINED_RISK=1000
PAPER_OPTION_MAX_SPREAD_WIDTH=10
MAX_DAILY_LOSS_PCT=
MAX_GROSS_EXPOSURE=

# Notifications
# Optional. If OQP_IBKR_HEARTBEAT_WEBHOOK_URL is blank, heartbeat scripts fall
# back to OQP_DISCORD_WEBHOOK_URL or OQP_HEALTH_WEBHOOK_URL.
OQP_DISCORD_WEBHOOK_URL=
OQP_HEALTH_WEBHOOK_URL=
OQP_LIVE_DISCORD_WEBHOOK_URL=
OQP_PORTFOLIO_DISCORD_WEBHOOK_URL=
OQP_PAPER_DISCORD_WEBHOOK_URL=
OQP_IBKR_HEARTBEAT_WEBHOOK_URL=

# Local storage
DATABASE_URL=sqlite:///runtime/db/oqp.sqlite3
PAPER_TRADING_DB_PATH=runtime/db/paper_trading/paper_trading.db
DATA_ROOT=runtime/data
ARTIFACT_ROOT=runtime/artifacts
LOG_LEVEL=INFO
