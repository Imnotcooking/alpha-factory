# Copy to /home/ubuntu/.oqp_server_env on the server and fill real values there.
# Keep permissions tight:
#   chmod 600 /home/ubuntu/.oqp_server_env
#
# Never commit a filled copy of this file.

# Repository/runtime
OQP_REPO_ROOT=/home/ubuntu/oqp_new
PYTHONPATH=src:.
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# IBKR Docker image
IB_GATEWAY_IMAGE=ghcr.io/gnzsnz/ib-gateway:latest

# IBKR login credentials for Docker only
IBKR_LIVE_USER=
IBKR_LIVE_PASSWORD=
IBKR_PAPER_USER=
IBKR_PAPER_PASSWORD=
# Optional. Leave blank if VNC is only started manually through SSH for MFA.
IBKR_VNC_PASSWORD=

# IBKR gateway ports exposed only on localhost
IBKR_LIVE_API_PORT=4001
IBKR_LIVE_CONTAINER_API_PORT=4001
IBKR_LIVE_VNC_PORT=5901
IBKR_PAPER_API_PORT=7497
IBKR_PAPER_CONTAINER_API_PORT=4004
IBKR_PAPER_VNC_PORT=5902
IBKR_EXISTING_SESSION_ACTION=primary
IBKR_PAPER_READ_ONLY_API=yes

# Application IBKR settings
IBKR_HOST=127.0.0.1
IBKR_LIVE_PORT=4001
IBKR_PAPER_PORT=7497
IBKR_LIVE_CLIENT_ID=201
IBKR_PAPER_CLIENT_ID=101
IBKR_PAPER_SNAPSHOT_CLIENT_ID=111
IBKR_PAPER_SUBMIT_CLIENT_ID=121
IBKR_LIVE_MONITOR_ENABLED=true

# Execution safety gates
ALLOW_LIVE_TRADING=false
ALLOW_PAPER_TRADING=false
ALLOW_PAPER_ORDER_SUBMIT=false
PAPER_MAX_ORDER_NOTIONAL=10000
PAPER_MAX_DAILY_NOTIONAL=50000
PAPER_ALLOWED_ASSET_CLASSES=equity,etf
PAPER_OPTIONS_ENABLED=false

# Vendor keys used by dashboards/jobs when available
FMP_API_KEY=
MASSIVE_API_KEY=
POLYGON_API_KEY=
OPTIONS_API_KEY=

# Discord notifications
OQP_DISCORD_WEBHOOK_URL=
OQP_PAPER_DISCORD_WEBHOOK_URL=
OQP_IBKR_HEARTBEAT_WEBHOOK_URL=
OQP_PORTFOLIO_HEALTH_MAX_AGE_HOURS=36
OQP_PAPER_HEALTH_MAX_AGE_HOURS=36
